# Cloudflare Pages redirects (copied into the deploy dir by deploy_docs.yml).
# Renamed Antora components: 301 old paths to new so old links and still-indexed
# URLs don't 404 (the former /main/ homepage, /samples/ playground).
/main/*      /home/:splat                    301
/samples/*   /spring-boot-playground/:splat  301

# Frozen release tags hardcode .html cross-links, but indexify serves extensionless
# dirs — 301 the known dead ones until the source project re-releases with clean URLs.
# (jhelm 1.0.0 performance page -> jvmlens / gotmpl4j sub-pages)
/jvmlens/current/usage.html                   /jvmlens/current/usage/                   301
/jvmlens/current/case-study-floatstring.html  /jvmlens/current/case-study-floatstring/  301
/gotmpl4j/current/performance.html            /gotmpl4j/current/performance/            301
/jhelm/current/performance.html               /jhelm/current/performance/               301

# jvmlens was briefly published as per-module Antora components (jvmlens-agent, -cli,
# -engine, -it, -jmh) when first added to the hub; now consolidated into one `jvmlens`
# component at /jvmlens/current/. Google indexed the old module URLs (GSC "Not found
# 404", 5 pages since 2026-06-12) — 301 them onto the real docs so they drop cleanly.
/jvmlens-agent/    /jvmlens/current/    301
/jvmlens-cli/      /jvmlens/current/    301
/jvmlens-engine/   /jvmlens/current/    301
/jvmlens-it/       /jvmlens/current/    301
/jvmlens-jmh/      /jvmlens/current/    301

# Yandex Webmaster fetches the verification file at its exact .html URL and needs a
# 200 — but Cloudflare Pages' clean-URLs 308-redirect .html -> extensionless, which
# Yandex won't follow. A 200 rewrite serves the file's content at the .html URL with
# no redirect. (status 200 = rewrite/serve-in-place, not a redirect.)
/yandex_8291effdcecec4ba.html  /yandex_8291effdcecec4ba  200
